# Server configuration (local development)
PORT=5000

# MongoDB connection string.
# - Local dev: mongodb://127.0.0.1:27017/shansofts
# - Production / Vercel: use a MongoDB Atlas URI (a localhost URI won't work from
#   Vercel's servers). Set this as an Environment Variable in the Vercel dashboard.
MONGODB_URI=mongodb://127.0.0.1:27017/shansofts

# Comma-separated list of allowed origins for CORS (frontend URLs).
# For a single Vercel project (frontend + /api on one domain) this is optional.
CLIENT_ORIGIN=http://localhost:5173

# --- Email (contact form notifications) ---
# Works with any SMTP provider (Hostinger, Gmail, Outlook, Zoho, SendGrid, etc.).
#
# Hostinger (recommended here — use your mailbox address + its password):
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465
#   SMTP_USER=info@shansofts.com
#   SMTP_PASS=your-mailbox-password
#
# Gmail: create an App Password at https://myaccount.google.com/apppasswords
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Where enquiry notifications are delivered (defaults to SMTP_USER if empty).
MAIL_TO=info@shansofts.com
# The "From" header (defaults to "Shansofts Website <SMTP_USER>").
MAIL_FROM=
